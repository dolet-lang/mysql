# ============================
#  MySQL Database Library for Dolet
# ============================
# Usage:
#   import mysql
#   db = MySQL.connect("localhost", "root", "password", "mydb", 3306)
module mysql
load mysql/bindings
load mysql/row
load mysql/result
load mysql/mysql

# Private — internal FFI bindings not exposed to users
private bindings

# Exported structs — public API
export MySQL
export MySQLResult
export MySQLRow
